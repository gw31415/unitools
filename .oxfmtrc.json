{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "sortImports": {
    "newlinesBetween": false
  },
  "sortTailwindcss": {
    "stylesheet": "src/style.css",
    "functions": ["clsx", "cn"],
    "preserveWhitespace": true
  },
  "sortPackageJson": {
    "sortScripts": true
  },
  "ignorePatterns": ["src/components/ui/**", "src/*.css", "worker-configuration.d.ts"]
}
