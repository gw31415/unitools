{
  "name": "unitools",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "check": "run-p check:*",
    "check:cf-typegen": "$npm_execpath run cf-typegen --check",
    "check:format": "oxfmt --check .",
    "check:lint": "oxlint .",
    "check:test": "vitest run --coverage=false",
    "check:types": "tsgo --noEmit",
    "deploy": "$npm_execpath run build && wrangler deploy",
    "dev": "vite",
    "format": "oxfmt .",
    "preview": "$npm_execpath run build && vite preview"
  },
  "dependencies": {
    "@hono/react-renderer": "^1.0.1",
    "@hono/standard-validator": "^0.2.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tiptap/core": "^3.20.1",
    "@tiptap/extension-collaboration": "^3.20.1",
    "@tiptap/extension-image": "^3.20.1",
    "@tiptap/markdown": "^3.20.1",
    "@tiptap/starter-kit": "^3.20.1",
    "@tiptap/static-renderer": "^3.20.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.8",
    "jotai": "^2.18.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "ulid": "^3.0.2",
    "y-durableobjects": "^1.0.5",
    "y-prosemirror": "^1.3.7",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.30",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.28.0",
    "@hono/cli": "^0.1.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260314.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/ui": "^4.1.0",
    "drizzle-kit": "^0.31.9",
    "jsdom": "^29.0.0",
    "npm-run-all": "^4.1.5",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.24.0",
    "shadcn": "^4.0.8",
    "tw-animate-css": "^1.4.0",
    "vite": "8.0.0",
    "vite-ssr-components": "^0.5.2",
    "vitest": "^4.1.0",
    "wrangler": "^4.73.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "leveldown",
      "msw",
      "sharp",
      "workerd"
    ]
  }
